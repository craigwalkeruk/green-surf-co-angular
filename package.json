{
  "name": "green-surf-co-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test-vrt": "npx vitest --browser",
    "test-vrt-docker": "docker build -f Dockerfile.vrt -t green-surf-vrt . && docker run --rm -v \"$PWD\":/app -v /app/node_modules green-surf-vrt 2>&1",
    "test-vrt-docker:watch": "docker build -f Dockerfile.vrt -t green-surf-vrt . && docker run --rm -it -v \"$PWD\":/app -v /app/node_modules green-surf-vrt npm run test-vrt-docker-run -- --watch",
    "test-vrt-docker-run": "npx vitest --config vitest.config.docker.ts",
    "storybook": "ng run green-surf-co:storybook",
    "build-storybook": "ng run green-surf-co:build-storybook"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/common": "^21.2.4",
    "@angular/compiler": "^21.2.4",
    "@angular/core": "^21.2.4",
    "@angular/platform-browser": "^21.2.4",
    "@storybook/addon-mcp": "^0.3.4",
    "class-variance-authority": "^0.7.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "vitest-preview": "^0.0.3"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.3.1",
    "@angular-devkit/architect": "^0.2102.2",
    "@angular-devkit/build-angular": "^21.2.2",
    "@angular-devkit/core": "^21.2.2",
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.4",
    "@angular/platform-browser-dynamic": "^21.2.4",
    "@angular/router": "^21.2.4",
    "@compodoc/compodoc": "^1.2.1",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.2.17",
    "@storybook/addon-designs": "^11.1.2",
    "@storybook/addon-docs": "^10.2.17",
    "@storybook/addon-onboarding": "^10.2.17",
    "@storybook/angular": "^10.2.17",
    "@tailwindcss/postcss": "^4.1.12",
    "@testing-library/angular": "^19.1.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "canvas": "^3.2.1",
    "jest-canvas-mock": "^2.5.2",
    "jsdom": "^28.0.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "storybook": "^10.2.17",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "vitest-browser-angular": "^0.3.0",
    "vitest-image-snapshot": "^0.6.47",
    "vitest-plugin-vis": "^4.1.0"
  }
}
